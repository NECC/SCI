generator client {
  provider = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public", "auth"]
}

model User {
  id             String        @id @default(uuid()) @map("id") @db.Uuid
  email          String        @unique
  password       String?
  name           String?
  role           String        @default("USER")
  picture        String?
  accredited     Boolean       @default(false)
  points         Int           @default(0)
  rewarded       Int           @default(0)
  hasTicket      Boolean       @default(false) @map("has_ticket")
  academicNumber Int?          @unique @map("academic_number")
  graduation     String?
  courseYear     Int?          @map("course_year")
  level          Int           @default(1)
  badges         String[]      @default([])
  streak         Int           @default(0)
  lastActivity   DateTime?
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  accounts       Account[]
  sessions       Session[]
  enrollments    Enrollments[]
  achievements Achievement[]

  @@map("app_users")
  @@schema("public")
}

model Activity {
  id          Int           @id @default(autoincrement())
  title       String
  description String?
  date        DateTime
  location    String
  capacity    Int?
  endTime     String
  startTime   String
  points      Int
  url         String?
  type        String
  enrollments Enrollments[]
  speakers    Speaker[]     @relation("ActivityToSpeaker")
  achievement String?
  
  //Relation 
  achievements Achievement[]

  @@schema("public")
}

model Speaker {
  id         Int        @id @default(autoincrement())
  name       String
  picUrl     String?
  activities Activity[] @relation("ActivityToSpeaker")
  @@schema("public")
}

model Enrollments {
  id         Int      @id @default(autoincrement())
  userId     String   @map("user_id") @db.Uuid
  activityId Int      @map("activity_id")
  attended   Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  activity   Activity @relation(fields: [activityId], references: [id])
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, activityId])
  @@map("enrollments")
  @@schema("public")
}

model Account {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String   @map("provider_account_id")
  refreshToken      String?  @map("refresh_token")
  accessToken       String?  @map("access_token")
  expiresAt         Int?     @map("expires_at")
  tokenType         String?  @map("token_type")
  scope             String?
  idToken           String?  @map("id_token")
  sessionState      String?  @map("session_state")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("app_accounts")
  @@schema("public")
}

model Achievement {
  id_achievement Int    @id @default(autoincrement())
  id_user        String @db.Uuid
  achievement_id Int
  type String?

  activity Activity @relation(fields: [achievement_id], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [id_user], references: [id], onDelete: Cascade)

  @@unique([id_user, achievement_id], name: "user_achievement_unique")
  @@map("achievements")
  @@schema("public")
}


model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime @db.Timestamptz(6)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("app_sessions")
  @@schema("public")
}
