generator client {
  provider = "prisma-client-js"
}

generator zod {
  provider = "zod-prisma-types"
  createInputTypes = false
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String        @id @default(uuid())

  // Credentials
  email          String        @unique
  password       String
  name           String
  role           Role          @default(USER)
  accredited     Boolean       @default(false) // if the user went to the event check-in

  // Ranking Attributes
  points         Int           @default(0) // total points of user
  rewarded       Int           @default(0) // number of times the user spinned the roulette
  hasTicket      Boolean       @default(false) // if the user has a roulette ticket

  // Presences Control
  academicNumber Int?          @unique /// @zod.number.min(1)
  graduation     Course?
  courseYear     Int?                  /// @zod.number.min(1).max(3)
  enrollments    Enrollments[]


  accounts       Account[]
  sessions       Session[]
}

model Activity {
  id          Int           @id @default(autoincrement())
  title       String
  description String?
  date        DateTime
  location    String
  capacity    Int?
  speakers    Speaker[]
  type        Type
  endTime     String
  startTime   String
  url         String?     // if activity has enrollment form
  points      Int
  enrollments Enrollments[]
}

model Speaker {
  id          Int           @id @default(autoincrement())
  name        String
  picUrl      String?
  activities  Activity[]
}

model Enrollments {
  id         Int      @id @default(autoincrement())
  userId     String
  activityId Int
  attended   Boolean
  activity   Activity @relation(fields: [activityId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, activityId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Type {
  WORKSHOP
  TALK
  TERTULIA
  OTHER
}

enum Role {
  USER
  ADMIN
  STAFF
}

enum Course {
  BIOLOGIA_APLICADA
  BIOLOGIA_E_GEOLOGIA
  BIOQUIMICA
  CIENCIA_DE_DADOS
  CIENCIAS_DA_COMPUTACAO
  CIENCIAS_DO_AMBIENTE
  ESTATISTICA_APLICADA
  FISICA
  GEOLOGIA
  MATEMATICA
  OPTOMETRIA_E_CIENCIAS_DA_VISAO
  QUIMICA
}
